# LLM — Primary
GOOGLE_API_KEY=your_google_api_key_here
GENERATION_MODEL=gemini-1.5-flash

# LLM — Fallback
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Models — Local (no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Tree Index build rate limiting
# Leave unset if billing is enabled (paid tier: ~1 min build at full speed)
# Set to 14 on free tier to stay under Gemini 1.5 Flash's 15 RPM cap (~98 min build)
# TREE_BUILD_RPM=14

# Retrieval
TOP_K=5                     # chunks to retrieve per strategy
CHUNK_SIZE=512              # tokens
CHUNK_OVERLAP=64            # tokens

# Paths
DATA_DIR=data/
RESULTS_DIR=results/
INDEX_DIR=data/indexes/
